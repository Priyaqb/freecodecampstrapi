{
  "kind": "collectionType",
  "collectionName": "blog_pages",
  "info": {
    "singularName": "blog-page",
    "pluralName": "blog-pages",
    "displayName": "Blog Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "blogtitle": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "blogtitle",
      "required": true
    },
    "Banner": {
      "type": "component",
      "component": "banner.hero-blog-banner",
      "repeatable": false
    },
    "blogcontent": {
      "type": "richtext"
    },
    "featuredimage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
